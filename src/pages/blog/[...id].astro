---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeBlockEnhancer from '../../components/CodeBlockEnhancer.astro';
import EmbedRenderer from '../../components/EmbedRenderer.astro';
import MermaidRenderer from '../../components/MermaidRenderer.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import SeriesCard from '../../components/SeriesCard.astro';
import SeriesNavigation from '../../components/SeriesNavigation.astro';
import { showSeriesUI } from '../../data/featureFlags';
import { getRelatedPosts } from '../../utils/getRelatedPosts';
import { getCurrentSeries, getSeriesPath, validateSeriesEntries } from '../../utils/series';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  validateSeriesEntries(allPosts);
  const posts = allPosts.filter((entry) => !entry.data.draft);
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const date = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'long', year: 'numeric', timeZone: 'UTC' })
  .format(post.data.publishedAt);
const toc = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const allPosts = await getCollection('blog');
validateSeriesEntries(allPosts);
const publishedPosts = allPosts.filter((entry) => !entry.data.draft);
const currentSeries = getCurrentSeries(post, publishedPosts);
const visibleCurrentSeries = showSeriesUI ? currentSeries : null;
const relatedArticles = getRelatedPosts(post, publishedPosts).map((relatedPost) => ({
  id: relatedPost.id,
  title: relatedPost.data.title
}));
const seriesIndexHref = visibleCurrentSeries
  ? getSeriesPath(visibleCurrentSeries.group.id, post.data.series?.order)
  : '';
---
<BaseLayout
  title={`${post.data.title} — PauloGerm.dev`}
  description={post.data.description}
  type="article"
  image={post.data.image}
>
  <div class="article-layout">
    <article class="article-prose">
      <a class="back-link" href="/blog">← Voltar ao arquivo</a>
      <header class="article-header">
        <div class="article-meta"><time>{date}</time><span>{post.data.tags.join(' · ')}</span></div>
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
      </header>
      {visibleCurrentSeries && (
        <SeriesCard
          title={visibleCurrentSeries.group.title}
          href={seriesIndexHref}
          currentIndex={visibleCurrentSeries.currentIndex}
          total={visibleCurrentSeries.total}
        />
      )}
      <div class="prose-body"><Content /></div>
      {visibleCurrentSeries && (
        <SeriesNavigation
          indexHref={seriesIndexHref}
          previous={visibleCurrentSeries.previous && {
            id: visibleCurrentSeries.previous.id,
            title: visibleCurrentSeries.previous.data.title
          }}
          next={visibleCurrentSeries.next && {
            id: visibleCurrentSeries.next.id,
            title: visibleCurrentSeries.next.data.title
          }}
        />
      )}
      <RelatedArticles articles={relatedArticles} />
    </article>

    {toc.length > 0 && (
      <aside class="article-toc">
        <p>Nesta nota</p>
        <nav>
          {toc.map((heading) => (
            <a class:list={[`depth-${heading.depth}`]} href={`#${heading.slug}`}>{heading.text}</a>
          ))}
        </nav>
      </aside>
    )}
  </div>
  <MermaidRenderer />
  <EmbedRenderer />
  <CodeBlockEnhancer />
</BaseLayout>
